# Copy to .env for local dev, or set these as environment variables on Render.

# Postgres connection string from Supabase (use the direct "postgres" role
# connection, not the pooled anon key, so the backend can bypass RLS).
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Comma-separated list of allowed frontend origins.
API_CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Where uploaded videos are stored on the container's filesystem.
UPLOAD_DIR=./data/uploads

# Path or name of the YOLOv11 weights file used for detection.
YOLO_MODEL=

# API key used for GPT-based natural-language explanations.
OPENAI_API_KEY=

# Maximum accepted upload size, in MB.
MAX_UPLOAD_MB=512
